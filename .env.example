# AutoMark configuration – copy to .env and adjust as needed.
# This file is loaded automatically at startup (via python-dotenv).
# All values shown are the built-in defaults.

# ── LLM / Ollama ──────────────────────────────────────────────────────────────
# Legacy analysis-model alias kept for backward compatibility.
AUTOMARK_MODEL_NAME=phi4-mini:3.8b-q4_K_M

# Preferred model for analysis-heavy tasks (rubric scoring, report prose).
AUTOMARK_ANALYSIS_MODEL_NAME=phi4-mini:3.8b-q4_K_M

# Lightweight model for short insights.
AUTOMARK_LIGHT_MODEL_NAME=gemma3:1b-it-q4_K_M

# Dedicated metadata extractor model for student number/name/assignment number extraction.
AUTOMARK_METADATA_EXTRACTOR_MODEL_NAME=hf.co/nimendraai/SmolLM2-360M-Assignment-Metadata-Extractor:Q4_K_M

# Base URL for the Ollama HTTP API.
AUTOMARK_OLLAMA_BASE_URL=http://localhost:11434

# Ollama generation/runtime controls.
AUTOMARK_NUM_CTX=4096
AUTOMARK_NUM_PREDICT=512

# Ollama daemon concurrency hint (set on the Ollama service/process, not AutoMark).
# Increase to >=2 to better utilize AutoMark's parallel report/insight requests.
OLLAMA_NUM_PARALLEL=2

# Set to false to skip prose LLM report generation and use template fallback.
AUTOMARK_LLM_REPORT_ENABLED=true

# PDF ingestion behavior:
# true  -> try regex first and skip LLM when both student_id and student_name are found
# false -> skip regex fast-path and always use model extraction for these details
AUTOMARK_PDF_REGEX_FAST_PATH_ENABLED=true

# ── Processing controls ────────────────────────────────────────────────────────
# Max characters sent from submission text to analysis model.
AUTOMARK_SUBMISSION_MAX_CHARS=8000

# Minimum number of past reports required before generating progression insights.
AUTOMARK_MIN_REPORTS_FOR_INSIGHTS=1

# ── Async batch job controls ────────────────────────────────────────────────────
# Number of worker threads processing queued batch jobs.
AUTOMARK_JOB_WORKER_CONCURRENCY=2

# Maximum number of queued jobs waiting in memory.
AUTOMARK_JOB_QUEUE_MAX_SIZE=100

# Default retries per batch item if grading fails.
AUTOMARK_JOB_MAX_RETRIES=1

# Max submissions accepted in one /grade/batch request.
AUTOMARK_BATCH_MAX_ITEMS=100

# Suggested retention window for completed jobs/artifacts.
AUTOMARK_JOB_RETENTION_DAYS=30

# Max size (bytes) allowed for generated CSV/JSON/PDF export artifacts.
AUTOMARK_EXPORT_MAX_BYTES=10485760

# ── Storage / output ───────────────────────────────────────────────────────────
AUTOMARK_DB_PATH=data/students.db
AUTOMARK_LOG_FILE=agent_trace.log
AUTOMARK_OUTPUT_PATH=output/feedback_report.md
AUTOMARK_ANALYSIS_REPORT_PATH=output/analysis_report.md
AUTOMARK_MARKING_SHEET_PATH=output/marking_sheet.md

# Base directory for API file inputs (submission/rubric relative paths).
AUTOMARK_DATA_BASE_DIR=data

# API server port used by local `python -m mas.api` entrypoint.
PORT=8000
