# AutoMark configuration – copy to .env and adjust as needed.
# All values shown are the built-in defaults; only set what you want to override.

# ── LLM / Ollama ──────────────────────────────────────────────────────────────
# Ollama model identifier (must be pulled with `make pull-model` or `ollama pull`)
AUTOMARK_MODEL_NAME=phi4-mini:3.8b-q4_K_M

# Base URL for the Ollama HTTP API
AUTOMARK_OLLAMA_BASE_URL=http://localhost:11434

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file used to persist grading results
AUTOMARK_DB_PATH=data/students.db

# Path for the structured JSON agent trace log
AUTOMARK_LOG_FILE=agent_trace.log

# ── Default data paths (CLI entry point) ──────────────────────────────────────
# Path to the student submission text file
AUTOMARK_SUBMISSION_PATH=data/submission.txt

# Path to the grading rubric JSON file
AUTOMARK_RUBRIC_PATH=data/rubric.json

# Output path for the generated Markdown feedback report
AUTOMARK_OUTPUT_PATH=output/feedback_report.md
